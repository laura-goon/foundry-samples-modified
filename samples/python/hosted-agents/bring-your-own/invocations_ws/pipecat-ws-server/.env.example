# Required: Azure Speech (used for STT and TTS).
# The fast-transcription endpoint is built as
#   https://{AZURE_SPEECH_REGION}.api.cognitive.microsoft.com/
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=eastus

# Required: Azure OpenAI (used by both LLM agents)
AZURE_FOUNDRY_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
AZURE_LLM_MODEL=gpt-4o-mini
