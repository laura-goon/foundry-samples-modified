# ============================================================================
# pipecat-ws-server browser portal config.
# ============================================================================

# Public Foundry endpoint, e.g.
#   https://{account}.services.ai.azure.com/api/projects/{project}
PROJECT_ENDPOINT=

# Hosted agent name (used in Foundry mode):
PIPECAT_WEBSOCKET_AGENT_NAME=pipecat-ws-server

# Optional local-server override. When set, the portal talks to the local
# server.py instead of the hosted agent (no Entra token needed):
# PIPECAT_WEBSOCKET_LOCAL_URL=ws://localhost:8088/invocations_ws

# --- Server bind ------------------------------------------------------------
# PORTAL_HOST=0.0.0.0
# PORTAL_PORT=9527

# --- Recorder ---------------------------------------------------------------
# Off: RECORD_CONVERSATION=0
# RECORDINGS_DIR=recordings
