# Required: Azure Speech (used for STT and TTS).
# The fast-transcription endpoint is built as
#   https://{AZURE_SPEECH_REGION}.api.cognitive.microsoft.com/
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=eastus

# Required: Azure OpenAI (used by both LLM agents)
AZURE_FOUNDRY_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
AZURE_LLM_MODEL=gpt-4o-mini

# Optional: TURN relay (a public STUN server is added automatically).
# Required for containerized deployments (Azure Container Apps, etc.) and
# behind symmetric NAT — without TURN, the browser cannot reach the server.
# WEBRTC_TURN_STUN_URL is optional: the TURN provider's own STUN endpoint,
# advertised alongside the relay so the browser can discover srflx candidates
# through the same host.
WEBRTC_TURN_URL=
WEBRTC_TURN_STUN_URL=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Server bind
SERVER_HOST=0.0.0.0
SERVER_PORT=8089
