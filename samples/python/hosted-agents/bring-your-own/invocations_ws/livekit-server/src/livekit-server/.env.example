# --- Azure Speech (STT + TTS) -----------------------------------------------
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=eastus

# --- Azure OpenAI (LLM) -----------------------------------------------------
AZURE_FOUNDRY_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_LLM_MODEL=gpt-4o-mini

# --- TTS voices (per agent) -------------------------------------------------
# Defaults are baked into agent.py:
#   GreeterAgent     -> en-US-Ava:DragonHDLatestNeural
#   CheckOrderAgent  -> en-US-Andrew:DragonHDLatestNeural
# Override here if needed.
# AZURE_TTS_VOICE_GREETER=en-US-Ava:DragonHDLatestNeural
# AZURE_TTS_VOICE_CHECK_ORDER=en-US-Andrew:DragonHDLatestNeural

# --- LiveKit server ---------------------------------------------------------
# Easiest: create a project at https://cloud.livekit.io and copy the values
# from `livekit settings keys`. The agent worker registers with this URL;
# the browser receives the same URL via the signaling WS and joins directly.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional override for the URL handed to BROWSERS. Useful only if the
# browser cannot reach LIVEKIT_URL (rare with LiveKit Cloud).
# LIVEKIT_PUBLIC_URL=

# Optional worker name used for explicit dispatch. Keep agent.py and
# server.py in sync if you change it; defaults to ``foundry-azure-voice``.
# LIVEKIT_AGENT_WORKER_NAME=foundry-azure-voice

# --- FastAPI signaling server -----------------------------------------------
# PORT=8091
