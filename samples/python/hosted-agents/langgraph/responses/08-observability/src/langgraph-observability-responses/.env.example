# Foundry project endpoint — auto-injected in hosted containers.
# Only set manually if running without `azd ai agent run`.
FOUNDRY_PROJECT_ENDPOINT=

# Model deployment name — must match a deployment in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Capture message/content payloads in GenAI spans.
# Default is false; set to true to record prompts, completions, and tool I/O.
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true

# --- Local telemetry only ----------------------------------------------------
# In hosted mode Foundry injects APPLICATIONINSIGHTS_CONNECTION_STRING for you.
# To ship spans from a local `python main.py` run, supply your own connection
# string here. OTEL_AUTO_CONFIGURE_AZURE_MONITOR is already set to true in
# agent.yaml / agent.manifest.yaml, but those values are only applied when
# running via `azd ai agent run` or after deploy — set it here too if you run
# the script directly.
#
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
# OTEL_AUTO_CONFIGURE_AZURE_MONITOR=true
