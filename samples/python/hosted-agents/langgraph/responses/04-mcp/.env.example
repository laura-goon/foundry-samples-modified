# Foundry project endpoint — auto-injected in hosted containers.
# Only set manually if running without `azd ai agent run`.
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Model deployment name — must match a deployment in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# GitHub Personal Access Token for the GitHub Copilot MCP server.
# Create one at https://github.com/settings/tokens with the scopes you
# want the agent to exercise (e.g. `repo`, `read:user`).
GITHUB_PAT=

# Optional: point at a different HTTP-transport MCP server.
# Defaults to https://api.githubcopilot.com/mcp/ when unset.
# MCP_SERVER_URL=
