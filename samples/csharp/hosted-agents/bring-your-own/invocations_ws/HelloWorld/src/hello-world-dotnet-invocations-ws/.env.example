# Voice Live AI Services account URL (no path) — used for LOCAL runs only.
# In Foundry-hosted runs the agent reads FOUNDRY_PROJECT_ENDPOINT instead.
# Examples:
#   https://my-vl.cognitiveservices.azure.com/
#   https://my-vl.services.ai.azure.com/
AZURE_VOICELIVE_ENDPOINT=

# Voice Live realtime model. (Hardcoded in agent.manifest.yaml for hosted runs.)
AZURE_VOICELIVE_MODEL=gpt-realtime-1.5

# Optional: voice (Azure or OpenAI). Default below.
# AZURE_VOICELIVE_VOICE=en-US-Ava:DragonHDLatestNeural

# Optional: system prompt. Default in Program.cs.
# AZURE_VOICELIVE_INSTRUCTIONS=You are a friendly, concise voice assistant.

# Optional: seconds of silence after which the agent proactively re-engages
# the user. Set to 0 to disable.
# AZURE_VOICELIVE_IDLE_ENGAGEMENT_SECONDS=20

# Application Insights — auto-injected in hosted containers.
# Set for local telemetry (optional but recommended).
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
