<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>AgentSkills</RootNamespace>
    <AssemblyName>agent-skills</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!--
      MAAI001 - Microsoft.Agents.AI experimental APIs (AgentSkillsProvider)
      AAIP001 - Azure.AI.Projects.Agents experimental APIs (ProjectAgentSkills)
      OPENAI001 - OpenAI Responses experimental APIs (Foundry Responses hosting)
      NU1903 / NU1605 - sample-only vulnerability/downgrade notices that are not actionable
    -->
    <NoWarn>$(NoWarn);MAAI001;AAIP001;OPENAI001;NU1903;NU1605</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Agent Framework core - provides AgentSkillsProvider and ChatClientAgent. -->
    <PackageReference Include="Microsoft.Agents.AI" Version="1.6.2" />
    <!-- Agent Framework hosting - provides AgentHost, AddFoundryResponses, MapFoundryResponses. -->
    <PackageReference Include="Microsoft.Agents.AI.Foundry.Hosting" Version="1.6.2-preview.260521.1" />
    <!-- Foundry SDK - provides AIProjectClient, AsAIAgent, and ProjectAgentSkills (Azure.AI.Projects.Agents). -->
    <PackageReference Include="Azure.AI.Projects" Version="2.1.0-beta.2" />
    <!-- .env file support for local development. -->
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
  </ItemGroup>

  <!-- Ship the source SKILL.md files in the publish output so the optional provisioning step
       can upload them to Foundry on the first run. The agent itself always downloads skills
       from Foundry at startup - the local 'skills/' folder is sample-onboarding only. -->
  <ItemGroup>
    <None Include="skills\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
