# Foundry project endpoint - auto-injected in hosted containers.
# Only set manually if running without `azd ai agent run`.
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Model deployment name - must match a deployment in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Comma-separated list of Foundry skill names to download at startup.
# These skills must already exist in the target Foundry project.
SKILL_NAMES=support-style,escalation-policy

# Sample convenience flag. Set to "true" on a first run to upload this sample's
# SKILL.md files to Foundry before downloading them. Leave unset or false in
# production - real deployments provision skills separately.
PROVISION_SAMPLE_SKILLS=true

# Application Insights - auto-injected in hosted containers.
# Set for local telemetry (optional but recommended).
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
