# Foundry project endpoint. Auto-injected in hosted containers.
# Only set manually if running without `azd ai agent run`.
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Chat model deployment name. Must match a deployment in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Azure AI Search service endpoint. Auto-derived from AZURE_AI_SEARCH_SERVICE_NAME
# by `azd ai agent run`. Set manually only when running without azd.
# AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net

# Search index name. Defaults to contoso-outdoors. The sample creates the index
# on startup if it does not exist and seeds three Contoso Outdoors documents.
AZURE_SEARCH_INDEX_NAME=contoso-outdoors

# Application Insights. Auto-injected in hosted containers.
# Set for local telemetry (optional but recommended).
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
