{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "enableMonitoring": {
      "value": "${ENABLE_MONITORING=true}"
    },
    "agentName": {
      "value": "${AGENT_NAME}"
    },
    "modelName": {
      "value": "${MODEL_NAME}"
    },
    "modelVersion": {
      "value": "${MODEL_VERSION}"
    }
  }
}
