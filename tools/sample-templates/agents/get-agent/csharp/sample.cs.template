// dotnet add package Azure.AI.Projects --version 1.2.*-*
using Azure.AI.Projects;
using Azure.AI.Projects.OpenAI;
<% if (useTokenCredentials) { %>
using Azure.Identity;
<% } %>
<% if (showOpenAIResponse) { %>
using OpenAI;
using OpenAI.Responses;
<% } %>

#pragma warning disable OPENAI001

<%= csharp.valueOrEnvironment(useEnvVars, "projectEndpoint", "AZURE_AI_FOUNDRY_PROJECT_ENDPOINT", projectEndpoint) %>
<%= csharp.valueOrEnvironment(useEnvVars, "agentName", "AZURE_AI_FOUNDRY_AGENT_NAME", agentName) %>

// Connect to your project using the endpoint from your project page
// The AzureCliCredential will use your logged-in Azure CLI identity, make sure to run `az login` first
AIProjectClient projectClient = new(endpoint: new Uri(projectEndpoint), tokenProvider: new DefaultAzureCredential());

<% if (useAsync) { %>
AgentRecord agentRecord = await projectClient.Agents.GetAgentAsync(agentName);
<% } else { %>
AgentRecord agentRecord = projectClient.Agents.GetAgent(agentName);
<% } %>
Console.WriteLine($"Agent retrieved (name: {agentRecord.Name}, id: {agentRecord.Id})");

<% if (showOpenAIResponse) { %>
ProjectResponsesClient responseClient = projectClient.OpenAI.GetProjectResponsesClientForAgent(agentRecord);
// Use the agent to generate a response
<% if (useAsync) { %>
ResponseResult response = await responseClient.CreateResponseAsync("Hello! Tell me a joke.");
<% } else { %>
ResponseResult response = responseClient.CreateResponse("Hello! Tell me a joke.");
<% } %>

Console.WriteLine(response.GetOutputText());
<% } %>